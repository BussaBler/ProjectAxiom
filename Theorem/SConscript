Import('baseEnv', 'debugEnv', 'releaseEnv', 'buildInfo')
from SCons.Script import Dir, Return

platform = buildInfo['platform']
architecture = buildInfo['architecture']
compiler = buildInfo['compiler']
config = buildInfo['config']
configName = config.capitalize()
vsproj = buildInfo['vsproj']

currentEnv = debugEnv if config.lower() == 'debug' else releaseEnv

theoremSrcDir = Dir('../../Theorem/Source')
theoremSources = theoremSrcDir.glob('*.cpp')

currentEnv.Append(CPPPATH=[
    '../../Theorem/Source',
    '../../Axiom/Source',
    '../../Axiom/Source/Axiom',
])

currentEnv.Prepend(LIBS=['Axiom', 'ImGui'])

currentEnv['OBJPREFIX'] = f'../Bin-Int/{platform}-{architecture}/{configName}/'

theoremApp = currentEnv.Program('Theorem', theoremSources)

theoremProject = None
if vsproj:
    theoremHeaders = theoremSrcDir.glob('*.h')

    currentEnv['CPPPATH'] = [Dir(path) for path in currentEnv['CPPPATH']]
    variant_key = f'{configName}|x64'
    dbg = {'LocalDebuggerWorkingDirectory': r'$(ProjectDir)..\\Build\\Theorem'}

    theoremProject = currentEnv.MSVSProject(
        target='../../Theorem/Theorem' + currentEnv['MSVSPROJECTSUFFIX'],
        srcs=[str(f) for f in theoremSources],
        incs=[str(f) for f in theoremHeaders],
        buildtarget=theoremApp,
        variant=[variant_key],
        auto_build_solution=0,
        DebugSettings=dbg
    )

Return('theoremApp', 'theoremProject')